# Virtual environment - never commit this. It's regenerated on any machine
# by running "pip install -r requirements.txt", committing it just bloats
# the repo with thousands of installed-package files that aren't our code.
venv/

# Python cache files - auto-generated bytecode, not source code, gets
# recreated automatically every time the program runs.
__pycache__/
*.pyc

# In case the program is ever run from a working directory other than /tmp
# and creates a local clone folder, don't accidentally commit cloned repos
# from other people's projects into our own repo.
blastradius_*/